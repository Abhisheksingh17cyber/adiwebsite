{
  "name": "adiwebsite-monorepo",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "install:all": "npm install && npm install --prefix frontend",
    "dev:frontend": "npm run dev --prefix frontend",
    "dev:api": "node api/index.js",
    "dev": "concurrently \"npm run dev:frontend\" \"npm run dev:api\"",
    "build:frontend": "npm run build --prefix frontend"
  },
  "dependencies": {
    "concurrently": "^9.1.2",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "nodemailer": "^6.9.16"
  }
}
